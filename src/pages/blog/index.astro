---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { site } from "../../site.config";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---
<Base
  title={`Blog & advice — ${site.name}`}
  description={`Advice and guides from ${site.name}.`}
  path="blog/"
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Blog &amp; advice</p>
      <h1>{(site as any).blogHeading ?? "Advice & guides"}</h1>
      <p>Honest, practical guidance — written for the people we serve.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card" data-reveal>
            <a class="post-thumb" href={`/blog/${post.id}/`} aria-label={post.data.title}></a>
            <div class="post-body">
              <p class="post-meta">{fmt(post.data.date)}</p>
              <h3><a href={`/blog/${post.id}/`} style="text-decoration:none;color:inherit">{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <a class="post-more" href={`/blog/${post.id}/`}>Read article &rarr;</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
