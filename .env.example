# Optional integrations.
# Copy to .env and fill in real values per deployment.
# Never commit .env.

# Form delivery (Formspree, Web3Forms, or your own webhook).
PUBLIC_FORM_ENDPOINT=

# Cloudflare Turnstile site key (public, safe to expose).
PUBLIC_TURNSTILE_SITE_KEY=

# Resend API key (server-only — only used in serverless functions).
# NOTE: this template ships static-only. There is no example serverless
# function in this repo that uses RESEND_API_KEY — wire it up yourself in
# a Cloudflare Pages Function or Vercel Function if you need transactional
# email. Remove this line if you do not.
RESEND_API_KEY=

# Stripe publishable key (public, safe to expose).
PUBLIC_STRIPE_PUBLISHABLE_KEY=
